#!/usr/bin/env bash
# Build and serve the DPD Pāḷi Courses website locally with MkDocs, running all pre-processing steps automatically.

echo "Starting DPD Pāḷi Courses build process..."

# Define the project root directory relative to the script location
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." >/dev/null 2>&1 && pwd)"

# Change to the project root
cd "$PROJECT_ROOT" || exit 1

uv run bash scripts/web_preprocessing.sh

echo "Starting MkDocs development server..."
echo "Press Ctrl+C to stop."
echo ""

uv run mkdocs serve
